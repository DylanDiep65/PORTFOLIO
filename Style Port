html,
body {
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: url("Dulan Port/aero.jpg") no-repeat center center fixed;
  background-size: cover;
  /* Always set a background-color as a fallback */
  background-color: #cccccc;
}


.masked-text {
    font-size: 5rem;
    font-weight: bold;
    color: transparent;
  text-align: center;
    background-image: url('Dulan Port/purplepattern.jpg'); 
    background-size: 200%; /* Enlarged for smooth animation */
    background-position: 0 50%;
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: animate-background 5s infinite alternate linear;
}

@keyframes animate-background {
    0% {
        background-position: 0 50%;
    }
    100% {
        background-position: 100% 50%;
    }
}
